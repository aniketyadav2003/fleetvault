RewriteEngine On

# Redirect /page.php to /page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^/]+)\.php\ HTTP/
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# Internal rewrite from /page to /page.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]
